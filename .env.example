# Authentication tokens (at least one required)
AUTH_TOKEN_1=your_secure_token_here
# AUTH_TOKEN_2=another_token

# Model API settings
MODEL_API_URL=your_model_api_url
MODEL_ID=your_model_id
MODEL_API_KEY=   # leave empty if not needed

# Output directory (writable)
OUTPUT_DIR=./outputs

# Limits
MAX_UPLOAD_SIZE_MB=100
PORT=8050