# Authentication tokens (at least one required)
AUTH_TOKEN_1=your_secure_token_here
# AUTH_TOKEN_2=another_token

# Model API settings
MODEL_API_URL=http://llm-api.kt-application.svc.cluster.local:8000/model/api/completions
MODEL_ID=69d0a234e26c20b56b5fbe2d
MODEL_API_KEY=   # leave empty if not needed

# File limits
MAX_UPLOAD_SIZE_MB=100
OUTPUT_DIR=/code/output

# Concurrency (0 = auto)
MAX_WORKERS=0
WORKER_RAM_GB=0.5

# Timeouts
MAX_JOB_DURATION=600
JOB_RETENTION_HOURS=24
STALE_JOB_THRESHOLD=900

# Rate limiting
RATE_LIMIT_RPM=30

# Resource thresholds
MIN_DISK_FREE_GB=1.0
MIN_RAM_FREE_MB=256